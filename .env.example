# ============================================================
# FRESHMART - Grocery E-Commerce Store
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================

# --- Flask App ---
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production

# --- Database ---
DATABASE_URL=sqlite:///freshmart.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/freshmart_db

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- IBM Watsonx.ai ---
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key-here
IBM_WATSONX_PROJECT_ID=your-watsonx-project-id-here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# --- Email (for OTP/verification) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=FreshMart <your-email@gmail.com>

# --- Session ---
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=86400

# --- Upload ---
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=app/static/images/products

# --- App Settings ---
APP_NAME=FreshMart
APP_TAGLINE=Fresh Groceries Delivered Fast
DELIVERY_FEE=49
FREE_DELIVERY_THRESHOLD=499
TAX_RATE=0.05

# --- Redis (optional, for caching) ---
# REDIS_URL=redis://localhost:6379/0

# --- Admin ---
ADMIN_EMAIL=admin@freshmart.com
ADMIN_PASSWORD=admin123
